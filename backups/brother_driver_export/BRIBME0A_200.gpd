*%******************************************************************************
*%                            MonochromeHalftone
*%******************************************************************************
*Feature: MonochromeHalftone
{
    *rcNameID: =IDS_GPD_HALFTONE
    *FeatureType: DOC_PROPERTY

    *DefaultOption: Dither

    *Option: Binary
    {
        *rcNameID: =IDS_GPD_BINARY
        *Command: CmdSelect
         {
             *Order: DOC_SETUP.8
         }
    }
    *Option: Dither
    {
        *rcNameID: =IDS_GPD_DITHER
        *Command: CmdSelect
         {
             *Order: DOC_SETUP.8
         }

}

*%******************************************************************************
*%                            PaperType
*%******************************************************************************
*Feature: PaperType
{
    *rcNameID: =IDS_GPD_PAPERTYPE
    *PrintSchemaKeywordMap: "PageMediaType"
    *FeatureType: DOC_PROPERTY
    *DefaultOption: CutSheet
    *Option: CutSheet
    {
        *rcNameID: =IDS_GPD_CUTSHEET
    }

    *Option: Roll
    {
        *rcNameID: =IDS_GPD_ROLL
        *Constraints: FormFeedMode.EndofPage
    }

    *Option: PerforatedRoll
    {
        *rcNameID: =IDS_GPD_PERFORATEDROLL
        *Constraints: FormFeedMode.FixedPage
        *Constraints: FormFeedMode.NoFeed
    }
    *Option: PerforatedRollRetract
    {
	*rcNameID: =IDS_GPD_PERFORATEDROLLRETRACT
	*Constraints: FormFeedMode.FixedPage
	*Constraints: FormFeedMode.NoFeed
	*Constraints: FormFeedMode.EndofPage
    }
}

